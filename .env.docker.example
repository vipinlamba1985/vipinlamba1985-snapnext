# Copy this file to .env.docker. Never commit real credentials.

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_IOS_APP_URL=
NEXT_PUBLIC_ANDROID_APP_URL=
JWT_SECRET=replace-with-at-least-32-random-characters
SNAPNEXT_OWNER_EMAILS=

# MongoDB
MONGODB_URI=
DB_NAME=snapnext

# Supabase authentication
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Storage: use local for development, s3 for production
STORAGE_PROVIDER=local
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=500
S3_SIGNED_URL_TTL=3600
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=

# Google Drive Smart Sync
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
CLOUD_CONNECTOR_SECRET=
CRON_SECRET=

# Optional cloud connectors
GOOGLE_PHOTOS_CLIENT_ID=
GOOGLE_PHOTOS_CLIENT_SECRET=
DROPBOX_CLIENT_ID=
DROPBOX_CLIENT_SECRET=
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_TENANT_ID=common

# AI providers
AI_DEFAULT_PROVIDER=groq
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# Controlled AI indexing
AI_INDEX_ENABLED=false
AI_WORKER_SECRET=
AI_IMAGE_ANALYSIS_MAX_BYTES=26214400
AI_VIDEO_ANALYSIS_MAX_BYTES=15728640

# Billing and email values should be copied from the existing Vercel environment
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
