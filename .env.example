# SnapNext AI providers — server-side only. Never expose these keys to the browser.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free

HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# Routing
AI_DEFAULT_PROVIDER=groq
PUBLIC_APP_URL=https://snapnext.ai
NEXT_PUBLIC_APP_URL=https://snapnext.ai

# Smart Sync secrets and provider credentials — server-side only.
CLOUD_CONNECTOR_SECRET=
CRON_SECRET=
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_PHOTOS_CLIENT_ID=
GOOGLE_PHOTOS_CLIENT_SECRET=
DROPBOX_CLIENT_ID=
DROPBOX_CLIENT_SECRET=
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_TENANT_ID=common

# Native app download destinations shown by the web Smart Sync page.
NEXT_PUBLIC_IOS_APP_URL=
NEXT_PUBLIC_ANDROID_APP_URL=

# Universal AI Index — controlled rollout. Keep false until QA and account-data cleanup are verified.
AI_INDEX_ENABLED=false
AI_WORKER_SECRET=
AI_IMAGE_ANALYSIS_MAX_BYTES=26214400
AI_VIDEO_ANALYSIS_MAX_BYTES=15728640
